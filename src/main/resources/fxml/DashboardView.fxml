<VBox prefHeight="708.0" prefWidth="784.0" spacing="30.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iesjc.keymasterclient.views.DashboardViewController">
