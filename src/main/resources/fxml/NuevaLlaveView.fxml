<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iesjc.keymasterclient.views.NuevaLlaveViewController">
    <children>

        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #17a2b8;">
            <children>
                <Label text="🔑 AÑADIR NUEVA LLAVE" textFill="WHITE">
                    <font> <Font name="System Bold" size="16.0" /> </font>
                </Label>
            </children>
            <padding> <Insets left="20.0" /> </padding>
        </HBox>

        <VBox spacing="15.0">
            <children>
                <Label text="DATOS DE LA LLAVE" textFill="#666666">
                    <font> <Font name="System Bold" size="12.0" /> </font>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Código Interno:" />
                        <TextField fx:id="txtCodigo" promptText="Introduce el código (ej. LL-105)" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="ID del Espacio Asignado:" />
                        <TextField fx:id="txtEspacio" promptText="ID numérico del espacio (ej. 1)" />
                        <Label text="* Nota: Temporalmente usamos el ID numérico hasta implementar el ComboBox de espacios." textFill="#999999">
                            <font> <Font size="10.0" /> </font>
                        </Label>
                    </children>
                </VBox>

                <Label fx:id="lblError" textFill="#dc3545" wrapText="true">
                    <font> <Font name="System Bold" size="12.0" /> </font>
                </Label>
            </children>
            <padding> <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /> </padding>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #f4f7f6;">
            <children>
                <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrarModal" style="-fx-background-color: transparent; -fx-cursor: hand;" text="CANCELAR" textFill="#666666">
                    <font> <Font name="System Bold" size="13.0" /> </font>
                </Button>
                <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#handleGuardar" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-cursor: hand;" text="GUARDAR Y AÑADIR LLAVE">
                    <font> <Font name="System Bold" size="13.0" /> </font>
                </Button>
            </children>
            <padding> <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /> </padding>
        </HBox>
    </children>
</VBox>