<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="708.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iesjc.keymasterclient.views.ReportesViewController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <Label text="Módulo de Reportes y Auditoría" textFill="#2b4c65">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;">
            <children>
                <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                    <children>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Tipo de Informe" textFill="#666666">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <ComboBox fx:id="cmbTipoInforme" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #cccccc; -fx-border-radius: 4;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Auditoría de Préstamos" />
                                            <String fx:value="Inventario de Llaves (Próximamente)" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="Auditoría de Préstamos" />
                                    </value>
                                </ComboBox>
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Rango de Tiempo" textFill="#666666">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <ComboBox fx:id="cmbRangoRapido" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #cccccc; -fx-border-radius: 4;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="HOY" />
                                            <String fx:value="SEMANA" />
                                            <String fx:value="MES" />
                                            <String fx:value="PERSONALIZADO" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="SEMANA" />
                                    </value>
                                </ComboBox>
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Desde (Inicio)" textFill="#666666">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <DatePicker fx:id="dpFechaInicio" prefHeight="35.0" prefWidth="130.0" style="-fx-border-color: #cccccc; -fx-border-radius: 4;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Hasta (Fin)" textFill="#666666">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <DatePicker fx:id="dpFechaFin" prefHeight="35.0" prefWidth="130.0" style="-fx-border-color: #cccccc; -fx-border-radius: 4;" />
                            </children>
                        </VBox>
      
                        <Button fx:id="btnVistaPrevia" mnemonicParsing="false" onAction="#handleVistaPrevia" prefHeight="35.0" prefWidth="117.0" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" text="👁 Ver Datos">
                            <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                            <padding>
                        <Insets left="15.0" right="15.0" />
                     </padding>
                        </Button>

                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <TableView fx:id="tablaPreview" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="Ref ID" />
                <TableColumn fx:id="colFecha" prefWidth="130.0" text="Fecha Transacción" />
                <TableColumn fx:id="colAccion" prefWidth="120.0" text="Tipo de Acción" />
                <TableColumn fx:id="colLlave" prefWidth="90.0" text="Llave" />
                <TableColumn fx:id="colDocente" prefWidth="170.0" text="Docente Implicado" />
                <TableColumn fx:id="colConserje" prefWidth="110.0" text="Operador (Conserje)" />
                <TableColumn fx:id="colObservaciones" prefWidth="160.0" text="Observaciones" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="840.0" spacing="15.0">
            <children>
                <Label fx:id="lblSuccess" textFill="#28a745" wrapText="true">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label fx:id="lblError" textFill="#dc3545" wrapText="true">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Region prefHeight="38.0" prefWidth="197.0" HBox.hgrow="ALWAYS" />

                  <Button fx:id="btnExportarPdf" mnemonicParsing="false" onAction="#handleExportarPdf" prefHeight="38.0" prefWidth="149.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" text="📄 Exportar PDF">
                      <font>
                  <Font name="System Bold" size="13.0" />
               </font>
                      <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
                  </Button>

                  <Button fx:id="btnExportarExcel" disable="true" mnemonicParsing="false" prefHeight="38.0" prefWidth="142.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" text="📊 Excel">
                      <font>
                  <Font name="System Bold" size="13.0" />
               </font>
                      <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
                  </Button>

                <Label fx:id="lblCargando" text="Procesando solicitud de auditoría..." textFill="#17a2b8" visible="false">
                    <font><Font name="System Italic" size="13.0" /></font>
                </Label>
            </children>
        </HBox>

    </children>
</VBox>
