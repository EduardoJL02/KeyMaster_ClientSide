<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iesjc.keymasterclient.views.MainLayoutController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label fx:id="lblViewTitle" text="Panel Principal" textFill="#2b4c65">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="15.0">
                    <children>
                        <Label fx:id="lblUserInfo" text="Bienvenido, Usuario" textFill="#666666">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-cursor: hand;" text="Cerrar Sesión" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="240.0" spacing="5.0" style="-fx-background-color: #2b4c65;">
            <children>
                <VBox alignment="CENTER" prefHeight="100.0" spacing="5.0">
                    <children>
                        <Label text="KM" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                        <Label text="KeyMaster Center" textFill="WHITE">
                            <font>
                                <Font name="System Italic" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Separator opacity="0.2" prefWidth="200.0" />

                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irADashboard" prefHeight="50.0" styleClass="menu-button" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Dashboard">
                    <font> <Font size="16.0" /> </font>
                    <padding> <Insets left="30.0" /> </padding>
                </Button>

                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irAInventario" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Inventario de Llaves">
                    <font> <Font size="16.0" /> </font>
                    <padding> <Insets left="30.0" /> </padding>
                </Button>

                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irAPersonas" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Personal / Profesores">
                    <font> <Font size="16.0" /> </font>
                    <padding> <Insets left="30.0" /> </padding>
                </Button>

                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irAPrestamos" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Préstamos Activos">
                    <font> <Font size="16.0" /> </font>
                    <padding> <Insets left="30.0" /> </padding>
                </Button>

                <VBox VBox.vgrow="ALWAYS" />

                <Button fx:id="btnSettings" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irASettings" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="Configuración">
                    <font> <Font size="16.0" /> </font>
                    <padding> <Insets left="30.0" /> </padding>
                </Button>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="pnlContent" prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: #f4f7f6;">
        </StackPane>
    </center>
</BorderPane>