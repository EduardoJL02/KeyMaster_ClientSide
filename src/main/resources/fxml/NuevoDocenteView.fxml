<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iesjc.keymasterclient.views.NuevoDocenteViewController">
    <children>

        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #17a2b8;">
            <children>
                <Label text="👤 AÑADIR NUEVO DOCENTE" textFill="WHITE">
                    <font> <Font name="System Bold" size="16.0" /> </font>
                </Label>
            </children>
            <padding> <Insets left="20.0" /> </padding>
        </HBox>

        <VBox spacing="15.0">
            <children>
                <Label text="DATOS PERSONALES Y ASIGNACIÓN" textFill="#666666">
                    <font> <Font name="System Bold" size="12.0" /> </font>
                </Label>

                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="DNI:" />
                                <TextField fx:id="txtDni" promptText="12345678X" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Nombre:" />
                                <TextField fx:id="txtNombre" promptText="Ej. Juan" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Apellidos:" />
                        <TextField fx:id="txtApellidos" promptText="Ej. Pérez Gómez" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Correo Electrónico Corporativo:" />
                        <TextField fx:id="txtEmail" promptText="juan.perez@ies.com" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="ID del Departamento:" />
                        <TextField fx:id="txtDepartamento" promptText="ID numérico (ej. 1 para Informática)" />
                    </children>
                </VBox>

                <Label fx:id="lblError" textFill="#dc3545" wrapText="true">
                    <font> <Font name="System Bold" size="12.0" /> </font>
                </Label>
            </children>
            <padding> <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /> </padding>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #f4f7f6;">
            <children>
                <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrarModal" style="-fx-background-color: transparent; -fx-cursor: hand;" text="CANCELAR" textFill="#666666">
                    <font> <Font name="System Bold" size="13.0" /> </font>
                </Button>
                <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#handleGuardar" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-cursor: hand;" text="REGISTRAR DOCENTE">
                    <font> <Font name="System Bold" size="13.0" /> </font>
                </Button>
            </children>
            <padding> <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /> </padding>
        </HBox>
    </children>
</VBox>